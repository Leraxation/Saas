# ── Sign in with Microsoft (the real product mode) ─────────────────────────
# Azure portal → App registrations → your app
AZURE_AD_CLIENT_ID=your-client-id
AZURE_AD_CLIENT_SECRET=your-client-secret          # Certificates & secrets → New client secret
AZURE_AD_TENANT_ID=common                          # or your tenant ID

# NextAuth session encryption — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret
NEXTAUTH_URL=http://localhost:3000                 # your deployed URL in production

# ── Optional: AI features (Jarvis + Daily Briefing) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional fallback A: server-side refresh token (single user, no sign-in)
MICROSOFT_REFRESH_TOKEN=

# ── Optional fallback B: Power Automate webhook mode ────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
WEBHOOK_SECRET=
