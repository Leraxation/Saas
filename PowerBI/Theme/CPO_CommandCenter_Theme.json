{
  "name": "CPO Command Center",
  "dataColors": [
    "#4FC3F7",
    "#81C784",
    "#FFB74D",
    "#E57373",
    "#BA68C8",
    "#4DD0E1",
    "#AED581",
    "#FF8A65"
  ],
  "good":    "#4CAF50",
  "neutral": "#FFC107",
  "bad":     "#F44336",
  "maximum": "#4FC3F7",
  "center":  "#90A4AE",
  "minimum": "#E57373",
  "null":    "#607D8B",
  "background":           "#0D1117",
  "foreground":           "#1C2333",
  "tableAccent":          "#4FC3F7",
  "visualStyles": {
    "*": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#1C2333" } } }],
        "border": [{ "color": { "solid": { "color": "#2D3748" } }, "radius": 8 }],
        "title": [{
          "fontColor": { "solid": { "color": "#E2E8F0" } },
          "background": { "solid": { "color": "#1C2333" } },
          "fontSize": 13,
          "bold": true
        }],
        "labels": [{
          "color": { "solid": { "color": "#CBD5E0" } },
          "fontSize": 11
        }]
      }
    },
    "card": {
      "*": {
        "calloutValue": [{
          "color": { "solid": { "color": "#4FC3F7" } },
          "fontSize": 32,
          "bold": true
        }],
        "label": [{
          "color": { "solid": { "color": "#90A4AE" } },
          "fontSize": 11
        }],
        "background": [{ "color": { "solid": { "color": "#1C2333" } } }]
      }
    },
    "tableEx": {
      "*": {
        "grid": [{
          "gridVertical": false,
          "gridHorizontalColor": { "solid": { "color": "#2D3748" } },
          "rowPadding": 6
        }],
        "columnHeaders": [{
          "fontColor": { "solid": { "color": "#90A4AE" } },
          "backColor": { "solid": { "color": "#252D3D" } },
          "fontSize": 11,
          "bold": true
        }],
        "values": [{
          "fontColorPrimary":   { "solid": { "color": "#E2E8F0" } },
          "fontColorSecondary": { "solid": { "color": "#CBD5E0" } },
          "backColorPrimary":   { "solid": { "color": "#1C2333" } },
          "backColorSecondary": { "solid": { "color": "#1A2332" } },
          "fontSize": 11
        }]
      }
    },
    "donutChart": {
      "*": {
        "legend": [{
          "color": { "solid": { "color": "#CBD5E0" } },
          "fontSize": 11
        }]
      }
    },
    "barChart": {
      "*": {
        "categoryAxis": [{
          "labelColor": { "solid": { "color": "#90A4AE" } },
          "fontSize": 10
        }],
        "valueAxis": [{
          "labelColor": { "solid": { "color": "#90A4AE" } },
          "gridlineColor": { "solid": { "color": "#2D3748" } },
          "fontSize": 10
        }]
      }
    },
    "gauge": {
      "*": {
        "calloutValue": [{
          "color": { "solid": { "color": "#4FC3F7" } },
          "fontSize": 24,
          "bold": true
        }]
      }
    }
  },
  "textClasses": {
    "callout": {
      "fontSize": 45,
      "fontFace": "Segoe UI",
      "color": "#4FC3F7"
    },
    "title": {
      "fontSize": 16,
      "fontFace": "Segoe UI Semibold",
      "color": "#E2E8F0"
    },
    "header": {
      "fontSize": 12,
      "fontFace": "Segoe UI",
      "color": "#90A4AE"
    },
    "label": {
      "fontSize": 10,
      "fontFace": "Segoe UI",
      "color": "#CBD5E0"
    }
  }
}
