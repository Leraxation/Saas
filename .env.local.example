# ── Option A: Microsoft Graph (direct) ──────────────────────────────────────
# Get these from portal.azure.com → App registrations
AZURE_AD_CLIENT_ID=your-client-id
AZURE_AD_CLIENT_SECRET=your-client-secret
AZURE_AD_TENANT_ID=your-tenant-id
# Run once to get this: python get_token.py
MICROSOFT_REFRESH_TOKEN=your-refresh-token

# ── Option B: Power Automate (webhook) ──────────────────────────────────────
# Create free database at upstash.com → Redis
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token
# Any random string — paste the same value into Power Automate flows
WEBHOOK_SECRET=pick-any-secret-string
